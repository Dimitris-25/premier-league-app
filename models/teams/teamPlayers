const pool = require("../../config/db");


async function insertTeamPlayer(player) {
  try {
    await pool.query(
      `INSERT INTO team_players 
        (team_id, player_id, season, position, number, captain) 
       VALUES (?, ?, ?, ?, ?, ?)
       ON DUPLICATE KEY UPDATE
          position = VALUES(position),
          number = VALUES(number),
          captain = VALUES(captain)`,
      [
        player.team_id,
        player.player_id,
        player.season,
        player.position || null,
        player.number || null,
        player.captain || 0
      ]
    );
  } catch (err) {
    console.error("❌ Error inserting player:", err);
    throw err;
  }
}



